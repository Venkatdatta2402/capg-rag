# =============================================================================
# pg-carag Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...

# --- Generation Model ---
# Options: gpt-4.1, gemini-pro
GENERATION_MODEL=gpt-4.1
GENERATION_PROVIDER=openai

# --- Context/Rephrase Model (lightweight, fast) ---
# Options: gpt-4o-mini, gemini-flash
CONTEXT_MODEL=gpt-4o-mini
CONTEXT_PROVIDER=openai

# --- Judge Model (Arch A uses separate model; Arch B reuses generation model) ---
JUDGE_MODEL=gpt-4o-mini
JUDGE_PROVIDER=openai

# --- Vector DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=capg_knowledge

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pg_carag

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Cross-Encoder Reranker ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Canary Deployment ---
CANARY_TRAFFIC_PERCENT=5
